# PostgreSQL — Supabase
# Use a URI do painel do Supabase.
# Se a senha tiver @, :, /, etc., ela precisa estar URL-encoded.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# SSL: Supabase usa TLS (default no código). Para Postgres local sem TLS:
# DATABASE_SSL=false

# Produção/Render: deixe false e aplique schema com `npx supabase@latest db push`.
# BATMOTOR_RUN_SCHEMA=false

# API
PORT=3000

# JWT
JWT_SECRET=YOUR_SECRET_KEY
JWT_EXPIRES_IN=8h

# Saídas de estoque >= valor exigem ADMIN ou GERENTE (padrão 500)
# LARGE_OUT_THRESHOLD=500

# CORS: origens extra (vírgula). Locais (5173/4173) já vêm por padrão.
#
# Depois que criar a URL do frontend, coloque ela no Render do backend:
#   CORS_ORIGINS=https://seu-front.onrender.com
#
# Alternativa para Netlify: permite qualquer subdomínio HTTPS *.netlify.app:
#   CORS_ALLOW_NETLIFY=true

# E-mail alertas (opcional)
# SMTP_HOST=
# SMTP_PORT=587
# ALERT_EMAIL_TO=

# Migração opcional Mongo → Postgres (`npm run db:migrate-from-mongo`)
# MONGODB_URI=mongodb://127.0.0.1:27017/batmotor
